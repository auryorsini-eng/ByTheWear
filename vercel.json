{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/groq", "dest": "/api/groq.js" },
    { "src": "/api/serp", "dest": "/api/serp.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
